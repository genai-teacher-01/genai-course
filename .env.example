# Modalità:
# - mock: per eseguire il codice in modalità mock, senza accedere a servizi esterni
# - vertex: chiama Gemini su GCP Vertex AI con service account
# - gemini_free: chiama Gemini Free usando API Key (GOOGLE_API_KEY), non richiede service account

LLM_MODE=mock

# Configurazione per Gemini su GCP Vertex AI
GOOGLE_CLOUD_PROJECT=hclsw-gpc-wrkld-auto
GOOGLE_CLOUD_LOCATION=us-east1
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json
GEMINI_MODEL=gemini-2.5-flash

# Configurazione RAG
CHROMA_PATH=./chroma_db
COLLECTION_NAME=hcl_day1_rag
TOP_K=3
CHUNK_SIZE=700
CHUNK_OVERLAP=120

